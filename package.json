{
  "name": "@linhtetpaing9/react-textblock-editor",
  "version": "0.5.0",
  "description": "ProseMirror rich text editor for React with formatting, tables, images, HTML source editing, and sanitized rendering.",
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "license": "MIT",
  "keywords": [
    "react",
    "rich-text",
    "editor",
    "prosemirror",
    "wysiwyg"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./themes/default.css": "./dist/themes/default.css",
    "./themes/dark.css": "./dist/themes/dark.css",
    "./themes/minimal.css": "./dist/themes/minimal.css",
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "dependencies": {
    "dompurify": "^3.3.1",
    "lucide-react": "^0.563.0",
    "orderedmap": "^2.1.1",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-view": "^1.41.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.11",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^3.2.0"
  },
  "scripts": {
    "dev": "vite --config vite.demo.config.ts",
    "build": "pnpm run build:lib && pnpm run build:docs",
    "build:lib": "vite build --config vite.lib.config.ts && node ./scripts/build-css.mjs && tsc -p tsconfig.lib.build.json",
    "build:docs": "vite build --config vite.demo.config.ts",
    "prepack": "npm run build:lib",
    "pack:check": "npm pack --dry-run",
    "preview": "vite preview --config vite.demo.config.ts",
    "typecheck": "pnpm run typecheck:lib && pnpm run typecheck:demo",
    "typecheck:lib": "tsc -p tsconfig.lib.json --noEmit",
    "typecheck:demo": "tsc -p tsconfig.demo.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  }
}
